# ── RoadBuddy AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# App
DEBUG=True

# Database (PostgreSQL — leave blank to use in-memory store during dev)
DATABASE_URL=postgresql://user:password@localhost:5432/roadbuddy

# AI APIs (leave blank to use mock data)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google Maps (for real routing & Places data)
GOOGLE_MAPS_API_KEY=

# JWT — change this to a long random string in production!
SECRET_KEY=change-this-to-a-long-random-string-in-production
