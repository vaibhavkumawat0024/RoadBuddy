# ── RoadBuddy AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# App
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=sqlite:///./roadbuddy.db

# AI APIs (leave blank to use mock data)
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Routing / Navigation APIs
OPEN_ROUTER_SERVICE_API_KEY=

# Email Dispatches
RESEND_API_KEY=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=kunalsinghtanwar355@gmail.com

# JWT — change this to a long random string in production!
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
